# Groq Cloud API Key (Fastest AI inference, starts with gsk_)
# Get your API key from Groq Console: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini API Key for the AI Advisor Chatbot Widget
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=

# Grok (xAI) API Key
# Get your API key from xAI console: https://console.x.ai/
XAI_API_KEY=
GROK_MODEL=grok-2

# NREL Developer API Key (optional, defaults to DEMO_KEY if not specified)
# Get your API key from NREL Developer site: https://developer.nrel.gov/signup/
NREL_API_KEY=DEMO_KEY

